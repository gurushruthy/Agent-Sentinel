# Worker engine selection
WORKER_EXECUTION_MODE=langgraph

# LangGraph step modes
LANGGRAPH_SEARCH_MODE=web
LANGGRAPH_SUMMARIZER_MODE=llm
LANGGRAPH_SAVE_MODE=sqlite

# Fallback behavior (set true only if you want deterministic fallback)
LANGGRAPH_SEARCH_FALLBACK=false
LANGGRAPH_SUMMARIZER_FALLBACK=false

# Search tuning
LANGGRAPH_SEARCH_TIMEOUT_SECONDS=15
LANGGRAPH_SEARCH_MAX_RESULTS=5

# LLM settings
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_TIMEOUT_SECONDS=20

# Save target
RESULTS_DB_PATH=data/results.db
